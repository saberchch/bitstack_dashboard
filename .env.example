# ─────────────────────────────────────────────────────────────────────────────
# BitStack Dashboard — Environment Variables
#
# Copy this file to .env and fill in your own values.
# The .env file is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key — used to sign JWT tokens and Flask sessions.
# Generate a strong random value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# PostgreSQL connection string (leave blank to use the local SQLite file)
# DATABASE_URL=postgresql://user:password@localhost:5432/bitstack

# Rate limiter backend (leave blank to use in-memory, or set a Redis URL)
# LIMITER_STORAGE_URI=redis://localhost:6379/0

# Flask port for local development
PORT=5001
